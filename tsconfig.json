{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "es2018",
    "declaration": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "outDir": "dist",
    "noUncheckedIndexedAccess": true,
    "preserveConstEnums" : true,
    "paths": {
      "@typescript-eslint/parser": ["./node_modules/@typescript-eslint/parser/dist"]
    }
  },
  "include": [
    "src/**/*.ts",
  ]
}